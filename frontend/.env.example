# DataMovers frontend — environment

# Where the backend API lives. The Vite dev server proxies `/api` and `/health`
# to this origin (see vite.config.ts), so the SPA stays origin-relative and
# there are no CORS issues in development. Only needed if the backend is not
# at http://localhost:8000.
VITE_API_PROXY_TARGET=http://localhost:8000
