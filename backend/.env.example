# ╔══════════════════════════════════════════════════════════════╗
# ║  DataMovers backend — environment configuration                ║
# ║  Copy to `.env` and fill in real values. NEVER commit `.env`.  ║
# ╚══════════════════════════════════════════════════════════════╝

# ── App ──────────────────────────────────────────────────────────
APP_NAME=DataMovers
ENVIRONMENT=development            # development | production
DEBUG=true

# ── Metadata database (our own Postgres — stores jobs/users/logs) ─
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=datamovers
POSTGRES_PASSWORD=change-me
POSTGRES_DB=datamovers

# ── JWT ──────────────────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Credential encryption (Fernet, for stored DB passwords) ──────
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_FERNET_KEY

# ── Celery / Redis (Memurai on Windows) ──────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Redpanda Connect engine ──────────────────────────────────────
# Path to the project-local binary (see README for download).
REDPANDA_CONNECT_BIN=bin/rpk-connect.exe

# ── First admin (bootstrapped on startup if no users exist) ──────
FIRST_ADMIN_EMAIL=admin@datamovers.local
FIRST_ADMIN_PASSWORD=change-me-admin

# ── CORS (React dev server) ──────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
